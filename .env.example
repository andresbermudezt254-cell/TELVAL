# ================================================================
# TELVAL Compras – Variables de entorno
# ================================================================
# 1. Ve a https://supabase.com → Tu proyecto → Settings → API
# 2. Copia los valores y pégalos aquí en un archivo llamado .env
# ================================================================

# Project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co

# Anon / public key (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service Role key – SOLO para el script de migración, NUNCA en el frontend
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Info de la app (opcionales)
VITE_APP_NAME=TELVAL Compras
VITE_APP_COMPANY=TELVAL S.A.S – Mantenimientos Metro
